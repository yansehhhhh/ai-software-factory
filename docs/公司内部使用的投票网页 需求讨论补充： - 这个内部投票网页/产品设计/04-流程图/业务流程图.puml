@startuml 业务流程图
 title 公司内部投票网页 - 业务流程图

 skinparam backgroundColor #FFFFFF
 skinparam activity {
   BackgroundColor #EFF6FF
   BorderColor #2563EB
   FontColor #111827
 }
 skinparam diamond {
   BackgroundColor #FEF3C7
   BorderColor #F59E0B
 }
 skinparam note {
   BackgroundColor #F9FAFB
   BorderColor #D1D5DB
 }

 start

 partition 管理员 {
   :使用邮箱/工号和密码登录;
 }

 partition 系统 {
   if (账号是否有效?) then (是)
     :识别用户角色;
   else (否)
     :提示账号或密码错误;
     stop
   endif
 }

 if (是否为管理员?) then (是)
   partition 管理员 {
     :进入管理员工作台;
     :选择创建投票;
     :填写标题、说明和结束时间;
     :选择实名或匿名;
     :选择单题或多题;
     :配置题型与题目;
   }

   partition 系统 {
     if (结束时间晚于当前时间?) then (是)
       if (题目配置是否有效?) then (是)
         :创建投票;
         :投票立即开始;
         :向所有员工开放参与入口;
       else (否)
         :提示题目或选项配置错误;
         stop
       endif
     else (否)
       :提示结束时间必须晚于当前时间;
       stop
     endif
   }
 else (否)
   partition 员工 {
     :进入投票列表;
   }
 endif

 partition 员工 {
   :使用邮箱/工号和密码登录;
   :查看进行中投票;
   :进入投票详情;
 }

 partition 系统 {
   if (投票是否已结束?) then (是)
     :禁用提交入口;
     :提示投票已结束;
   else (否)
     if (员工是否已提交?) then (是)
       :展示已提交状态;
       :禁止重复提交和修改;
     else (否)
       partition 员工 {
         :填写单选/多选/评分/文本反馈答案;
         :点击提交;
         :确认提交后不可修改;
       }
       partition 系统 {
         if (必答题是否完成?) then (是)
           :保存答案;
           :锁定该员工本次投票提交记录;
           :标记已提交;
         else (否)
           :提示完成必答题;
           stop
         endif
       }
     endif
   endif
 }

 partition 系统 {
   if (到达结束时间或管理员提前结束?) then (是)
     :投票状态变更为已结束;
     :生成统计结果;
   else (否)
     :继续接受未提交员工投票;
   endif
 }

 partition 员工 {
   :查看已结束投票结果;
 }

 partition 系统 {
   if (投票为匿名?) then (是)
     :展示汇总统计和图表;
     :不展示投票人与答案映射;
   else (否)
     :普通员工查看汇总统计和图表;
     :管理员可查看实名明细;
   endif
 }

 stop
 @enduml
