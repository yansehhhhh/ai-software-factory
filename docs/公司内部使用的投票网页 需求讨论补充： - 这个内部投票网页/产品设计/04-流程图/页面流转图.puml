@startuml 页面流转图
 title 公司内部投票网页 - 页面流转图

 skinparam backgroundColor #FFFFFF
 skinparam rectangle {
   BackgroundColor #EFF6FF
   BorderColor #2563EB
   FontColor #111827
   RoundCorner 12
 }
 skinparam diamond {
   BackgroundColor #FEF3C7
   BorderColor #F59E0B
 }
 skinparam arrow {
   Color #4B5563
 }

 rectangle "登录页\n/Login" as Login
 diamond "角色判断" as RoleCheck

 rectangle "员工投票列表\n/Votes" as EmployeeVotes
 rectangle "投票详情页\n/Votes/{id}" as VoteDetail
 rectangle "提交确认弹窗\nSubmitConfirm" as SubmitConfirm
 rectangle "已提交状态页/提示\nSubmittedState" as SubmittedState
 rectangle "投票结果页\n/Votes/{id}/Result" as VoteResult

 rectangle "管理员工作台\n/Admin/Dashboard" as AdminDashboard
 rectangle "创建投票页\n/Admin/Votes/Create" as CreateVote
 rectangle "投票管理页\n/Admin/Votes" as ManageVotes
 rectangle "管理端投票详情\n/Admin/Votes/{id}" as AdminVoteDetail
 rectangle "员工账号导入页\n/Admin/Employees/Import" as ImportEmployees
 rectangle "导入结果页/弹窗\nImportResult" as ImportResult
 rectangle "结果明细页\n/Admin/Votes/{id}/Result" as AdminResult

 [*] --> Login
 Login --> RoleCheck : 登录成功
 Login --> Login : 登录失败/提示错误

 RoleCheck --> EmployeeVotes : 员工
 RoleCheck --> AdminDashboard : 管理员

 EmployeeVotes --> VoteDetail : 点击进行中投票
 EmployeeVotes --> VoteResult : 点击已结束投票结果
 VoteDetail --> SubmitConfirm : 点击提交
 SubmitConfirm --> VoteDetail : 取消
 SubmitConfirm --> SubmittedState : 确认提交成功
 VoteDetail --> SubmittedState : 已提交用户进入
 SubmittedState --> EmployeeVotes : 返回列表
 SubmittedState --> VoteResult : 投票已结束后查看结果
 VoteResult --> EmployeeVotes : 返回列表

 AdminDashboard --> CreateVote : 创建投票
 AdminDashboard --> ManageVotes : 查看投票管理
 AdminDashboard --> ImportEmployees : 导入员工账号

 CreateVote --> ManageVotes : 创建成功并立即开始
 CreateVote --> AdminDashboard : 取消创建

 ManageVotes --> AdminVoteDetail : 查看/管理投票
 ManageVotes --> AdminResult : 查看已结束结果
 AdminVoteDetail --> AdminResult : 查看结果/统计
 AdminVoteDetail --> ManageVotes : 返回列表
 AdminResult --> ManageVotes : 返回管理页

 ImportEmployees --> ImportResult : 上传并校验导入
 ImportResult --> ImportEmployees : 继续导入
 ImportResult --> AdminDashboard : 完成

 EmployeeVotes --> Login : 退出登录
 AdminDashboard --> Login : 退出登录
 ManageVotes --> Login : 退出登录

 @enduml
